{
  "name": "artofwoo",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --port 4000",
    "build": "tsc && vite build",
    "build:event-ops": "tsc && vite build --config vite.event-ops.config.ts",
    "postbuild:event-ops": "powershell -NoProfile -Command \"if (Test-Path 'dist-event-ops/event-ops.html') { Move-Item -Force 'dist-event-ops/event-ops.html' 'dist-event-ops/index.html' }; Copy-Item -Force 'event-ops/.htaccess' 'dist-event-ops/.htaccess'\"",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.9",
    "@vitejs/plugin-react": "^5.1.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "convex": "^1.34.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  }
}
