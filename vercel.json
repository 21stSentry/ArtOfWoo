{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/media-package", "destination": "/media-package.html" },
    { "source": "/media-package/", "destination": "/media-package.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
